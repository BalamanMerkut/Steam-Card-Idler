<Application x:Class="SteamCardIdler.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
             xmlns:local="clr-namespace:SteamCardIdler.Helpers"
             StartupUri="MainWindow.xaml">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ui:ThemesDictionary Theme="Dark"/>
                <ui:ControlsDictionary/>
            </ResourceDictionary.MergedDictionaries>

            <local:BooleanToVisibilityConverter        x:Key="BooleanToVisibilityConverter"/>
            <local:InverseBooleanToVisibilityConverter x:Key="InverseBooleanToVisibilityConverter"/>
            <local:NullOrEmptyToCollapsedConverter     x:Key="NullOrEmptyToCollapsedConverter"/>
            <local:SortModeToBackgroundConverter       x:Key="SortModeToBackgroundConverter"/>
        </ResourceDictionary>
    </Application.Resources>
</Application>
