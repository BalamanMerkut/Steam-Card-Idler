<UserControl x:Class="SteamCardIdler.Views.LoginView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:local="clr-namespace:SteamCardIdler.Helpers"
             mc:Ignorable="d"
             d:DesignHeight="650" d:DesignWidth="1000">

    <Grid>
        <!-- Background Gradient -->
        <Border>
            <Border.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                    <GradientStop Color="#0F111A" Offset="0"/>
                    <GradientStop Color="#1A1D2E" Offset="1"/>
                </LinearGradientBrush>
            </Border.Background>
        </Border>

        <!-- Language selector - top right corner -->
        <StackPanel Orientation="Horizontal" VerticalAlignment="Top" HorizontalAlignment="Right" Margin="0,16,20,0">
            <TextBlock Text="{Binding Strings[Language], FallbackValue='Language:'}"
                       Foreground="Gray" FontSize="12" VerticalAlignment="Center" Margin="0,0,8,0"/>
            <ComboBox ItemsSource="{Binding Languages}"
                      SelectedItem="{Binding SelectedLanguage}"
                      Width="110" Padding="8,4"/>
        </StackPanel>

        <!-- Login Card -->
        <ui:Card VerticalAlignment="Center" HorizontalAlignment="Center"
                 Width="400" Padding="40" Background="#1E2235" BorderBrush="#2D3250">
            <StackPanel>
                <ui:SymbolIcon Symbol="ShieldLock48" Filled="True" Foreground="#4A90E2"
                               HorizontalAlignment="Center" Margin="0,0,0,20"/>

                <TextBlock Text="{Binding Strings[LoginTitle], FallbackValue='Steam Hesabına Bağlan'}"
                           FontSize="22" FontWeight="Bold" Foreground="White"
                           HorizontalAlignment="Center" Margin="0,0,0,5"
                           TextWrapping="Wrap" TextAlignment="Center"/>

                <TextBlock Text="{Binding Strings[LoginSubtitle], FallbackValue='Hesap bilgileriniz kaydedilmez.'}"
                           FontSize="13" Foreground="Gray"
                           HorizontalAlignment="Center" Margin="0,0,0,30"/>

                <TextBox Text="{Binding Username, UpdateSourceTrigger=PropertyChanged}"
                         Padding="10" Margin="0,0,0,12"/>

                <PasswordBox Padding="10" Margin="0,0,0,12" Name="PassBox"
                             local:PasswordBoxHelper.Attach="True"
                             local:PasswordBoxHelper.Password="{Binding Password, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>

                <!-- Steam Guard -->
                <StackPanel Visibility="{Binding IsGuardRequired, Converter={StaticResource BooleanToVisibilityConverter}}"
                            Margin="0,0,0,12">
                    <TextBlock Text="{Binding Strings[GuardCodeLabel], FallbackValue='Steam Guard Kodu'}"
                               Foreground="Gray" FontSize="11" Margin="0,0,0,5"/>
                    <TextBox Text="{Binding GuardCode, UpdateSourceTrigger=PropertyChanged}" Padding="10"/>
                </StackPanel>

                <!-- Login Button -->
                <Button IsDefault="True" HorizontalAlignment="Stretch"
                        Padding="0,15" Command="{Binding LoginCommand}" Margin="0,10,0,10">
                    <Grid>
                        <TextBlock Text="{Binding Strings[LoginButton], FallbackValue='Giriş Yap'}"
                                   Visibility="{Binding IsLoggingIn, Converter={StaticResource InverseBooleanToVisibilityConverter}}"/>
                        <ui:ProgressRing IsIndeterminate="True" Height="20" Width="20"
                                         Visibility="{Binding IsLoggingIn, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                    </Grid>
                </Button>

                <TextBlock Text="{Binding LastLogMessage}"
                           Foreground="#4A90E2" FontSize="11"
                           HorizontalAlignment="Center" Margin="0,5,0,5"/>

                <TextBlock Text="{Binding LoginErrorMessage}"
                           Foreground="#FF5F5F" HorizontalAlignment="Center"
                           TextWrapping="Wrap" FontWeight="SemiBold"/>

                <!-- Developer -->
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,30,0,0">
                    <TextBlock Text="{Binding Strings[Developer], FallbackValue='Geliştirici:'}" Foreground="Gray"/>
                    <TextBlock Text=" Alejandev" Foreground="#4A90E2" FontWeight="SemiBold"/>
                </StackPanel>
            </StackPanel>
        </ui:Card>
    </Grid>
</UserControl>
