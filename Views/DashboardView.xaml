<UserControl x:Class="SteamCardIdler.Views.DashboardView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:local="clr-namespace:SteamCardIdler.Helpers"
             mc:Ignorable="d" 
             d:DesignHeight="650" d:DesignWidth="1000">

    <Grid Margin="20">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="300"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Sidebar / Controls -->
        <ScrollViewer Grid.Column="0" VerticalScrollBarVisibility="Auto" Margin="0,0,20,0">
            <StackPanel>
                <!-- User Profile Card -->
                <ui:Card Padding="14" Margin="0,0,0,15" Background="#1E2235" BorderBrush="#2D3250">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <Ellipse Grid.Column="0" Height="46" Width="46" Margin="0,0,10,0">
                            <Ellipse.Fill>
                                <ImageBrush ImageSource="{Binding UserProfile.AvatarUrl}" Stretch="UniformToFill"/>
                            </Ellipse.Fill>
                        </Ellipse>
                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                            <TextBlock Text="{Binding UserProfile.PersonaName}" FontWeight="Bold" FontSize="15"
                                       Foreground="White" TextTrimming="CharacterEllipsis"/>
                            <StackPanel Orientation="Horizontal" Margin="0,3,0,0">
                                <Ellipse Fill="{Binding StatusBrush}" Height="7" Width="7" Margin="0,0,5,0"/>
                                <TextBlock Text="{Binding StatusText}" Foreground="Gray" FontSize="11"/>
                            </StackPanel>
                        </StackPanel>
                        <Button Grid.Column="2" Command="{Binding LogoutCommand}"
                                ToolTip="{Binding Strings[Logout], FallbackValue='Logout'}"
                                Background="Transparent" BorderThickness="0"
                                Padding="6" VerticalAlignment="Center">
                            <ui:SymbolIcon Symbol="SignOut24" Foreground="#888"/>
                        </Button>
                    </Grid>
                </ui:Card>

                <!-- Control Buttons -->
                <ui:Card Padding="15" Margin="0,0,0,15" Background="#1E2235" BorderBrush="#2D3250">
                    <StackPanel>
                        <!-- Start Idling Button -->
                        <Button Command="{Binding StartIdleCommand}" Background="#4CAF50" Foreground="White" Margin="0,0,0,10" Padding="12" HorizontalAlignment="Stretch">
                            <Button.Style>
                                <Style TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsIdling}" Value="True">
                                            <Setter Property="Effect">
                                                <Setter.Value>
                                                    <DropShadowEffect Color="#4CAF50" BlurRadius="25" ShadowDepth="0" Opacity="1.0" RenderingBias="Quality"/>
                                                </Setter.Value>
                                            </Setter>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                <ui:SymbolIcon Symbol="Play24" Margin="0,0,8,0" Foreground="White"/>
                                <TextBlock Text="{Binding Strings[Start]}" FontWeight="Bold" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                        
                        <!-- Pause and Stop Buttons -->
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="10"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Button Grid.Column="0" Command="{Binding PauseResumeCommand}" Padding="8">
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                    <ui:SymbolIcon Symbol="Pause24" Margin="0,0,5,0"/>
                                    <TextBlock Text="{Binding PauseButtonText}" VerticalAlignment="Center" FontSize="12"/>
                                </StackPanel>
                            </Button>
                            <Button Grid.Column="2" Command="{Binding StopIdleCommand}" Background="#E53935" Foreground="White" Padding="8">
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                    <ui:SymbolIcon Symbol="Stop24" Margin="0,0,5,0" Foreground="White"/>
                                    <TextBlock Text="{Binding Strings[Stop]}" VerticalAlignment="Center" FontSize="12"/>
                                </StackPanel>
                            </Button>
                        </Grid>

                        <!-- Scan Games Button -->
                        <Button Command="{Binding RefreshGamesCommand}" Margin="0,12,0,0" Padding="12,10" HorizontalAlignment="Stretch"
                                Background="#2D3250" Foreground="White">
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                <ui:ProgressRing Height="16" Width="16" Margin="0,0,8,0" IsIndeterminate="True" 
                                                 Visibility="{Binding IsRefreshingGames, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                                <ui:SymbolIcon Symbol="ArrowCounterclockwise24" Margin="0,0,8,0" Foreground="White"
                                               Visibility="{Binding IsRefreshingGames, Converter={StaticResource InverseBooleanToVisibilityConverter}}"/>
                                <TextBlock Text="{Binding Strings[RefreshGames]}" VerticalAlignment="Center" FontWeight="SemiBold"/>
                            </StackPanel>
                        </Button>
                    </StackPanel>
                </ui:Card>

                <!-- Estimated Earnings -->
                <ui:Card Padding="12" Margin="0,0,0,15" Background="#1A2235" BorderBrush="#2D3250"
                         Visibility="{Binding TotalEstimatedValue, Converter={StaticResource NullOrEmptyToCollapsedConverter}, FallbackValue=Collapsed}">
                    <StackPanel>
                        <TextBlock Text="{Binding Strings[EstimatedValueTitle]}" Foreground="Gray" FontSize="10" FontWeight="SemiBold" Margin="0,0,0,4"/>
                        <TextBlock Text="{Binding TotalEstimatedValue}" Foreground="#4CAF50" FontSize="15" FontWeight="Bold"/>
                    </StackPanel>
                </ui:Card>

                <!-- Log Entries -->
                <StackPanel Orientation="Horizontal" Margin="0,5,0,8">
                    <TextBlock Text="{Binding Strings[LogEntries]}" FontWeight="SemiBold" Foreground="Gray" FontSize="10" VerticalAlignment="Center"/>
                    <TextBlock Text="{Binding ScanProgressText}" Margin="10,0,0,0" FontSize="10" Foreground="#4A90E2" FontWeight="Bold" VerticalAlignment="Center"/>
                </StackPanel>
                <ui:Card Padding="12" Background="#161926" BorderBrush="#2D3250">
                    <ItemsControl ItemsSource="{Binding LogEntries}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding}" FontSize="11" Margin="0,2,0,2" TextWrapping="Wrap" Foreground="#A0A0A0"/>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ui:Card>

                <!-- Support Button -->
                <ui:Card Padding="10" Margin="0,15,0,15" Background="#1A2235" BorderBrush="#2D3250">
                    <TextBlock HorizontalAlignment="Center" FontSize="12">
                        <Run Text="{Binding Strings[Support]}" Foreground="Gray"/>
                        <Hyperlink Command="{Binding OpenPatreonCommand}" Foreground="#F96854" TextDecorations="None">
                            <Run Text=" Patreon" FontWeight="Bold"/>
                        </Hyperlink>
                    </TextBlock>
                </ui:Card>
            </StackPanel>
        </ScrollViewer>

        <!-- Main Content / Games -->
        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Top Toolbar (Sorting and Filters) -->
            <Grid Grid.Row="0" Margin="0,0,0,15">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/> <!-- Sorting -->
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/> <!-- Selection / VAC -->
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="{Binding Strings[Sort]}" VerticalAlignment="Center" Foreground="Gray" FontSize="12" Margin="0,0,8,0"/>
                    <Button Content="Kart ↓" Command="{Binding SortByCardCountDescCommand}" Padding="10,5" Margin="0,0,5,0"
                            Background="{Binding CurrentSortMode, Converter={StaticResource SortModeToBackgroundConverter}, ConverterParameter=CardCountDesc}"/>
                    <Button Content="Kart ↑" Command="{Binding SortByCardCountAscCommand}"  Padding="10,5" Margin="0,0,5,0"
                            Background="{Binding CurrentSortMode, Converter={StaticResource SortModeToBackgroundConverter}, ConverterParameter=CardCountAsc}"/>
                    <Button Content="A → Z"  Command="{Binding SortByNameAscCommand}"        Padding="10,5" Margin="0,0,5,0"
                            Background="{Binding CurrentSortMode, Converter={StaticResource SortModeToBackgroundConverter}, ConverterParameter=NameAsc}"/>
                    <Button Content="Z → A"  Command="{Binding SortByNameDescCommand}"       Padding="10,5" Margin="0,0,5,0"
                            Background="{Binding CurrentSortMode, Converter={StaticResource SortModeToBackgroundConverter}, ConverterParameter=NameDesc}"/>
                </StackPanel>

                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                    <ui:ToggleSwitch Content="{Binding Strings[VacOnly]}" IsChecked="{Binding FilterVacOnly}" Margin="0,0,15,0"/>
                    <Button Content="{Binding Strings[SelectAll]}"    Command="{Binding SelectAllCommand}"   Margin="4,0" Padding="15,8"/>
                    <Button Content="{Binding Strings[DeselectAll]}" Command="{Binding DeselectAllCommand}" Margin="4,0" Padding="15,8"/>
                </StackPanel>
            </Grid>

            <!-- Game Cards List -->
            <ListView ItemsSource="{Binding SortedGames}" Grid.Row="2" Background="Transparent" BorderThickness="0"
                      Visibility="{Binding IsRefreshingGames, Converter={StaticResource InverseBooleanToVisibilityConverter}}"
                      HorizontalContentAlignment="Stretch" ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                <ListView.ItemsPanel>
                    <ItemsPanelTemplate>
                        <WrapPanel Orientation="Horizontal" />
                    </ItemsPanelTemplate>
                </ListView.ItemsPanel>
                <ListView.ItemTemplate>
                    <DataTemplate>
                        <Border CornerRadius="8" Margin="6,8,6,12" Width="215" Height="Auto" MinHeight="280"
                                BorderBrush="#333" BorderThickness="1">
                            <Border.Style>
                                <Style TargetType="Border">
                                    <Setter Property="Background" Value="#1A1A2E"/>
                                    <Setter Property="Opacity" Value="1.0"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsBlacklisted}" Value="True">
                                            <Setter Property="Opacity" Value="0.4"/>
                                            <Setter Property="Background" Value="#0F0F1A"/>
                                        </DataTrigger>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Background" Value="#252540"/>
                                        </Trigger>
                                        <MultiDataTrigger>
                                            <MultiDataTrigger.Conditions>
                                                <Condition Binding="{Binding IsBlacklisted}" Value="True"/>
                                                <Condition Binding="{Binding RelativeSource={RelativeSource Self}, Path=IsMouseOver}" Value="True"/>
                                            </MultiDataTrigger.Conditions>
                                            <Setter Property="Background" Value="#0F0F1A"/>
                                        </MultiDataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="120"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>
                                
                                <!-- Game header image -->
                                <Border Grid.Row="0" CornerRadius="8,8,0,0" ClipToBounds="True">
                                    <Image Source="{Binding HeaderUrl}" Stretch="UniformToFill" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                                </Border>

                                <!-- Selection checkbox - over image -->
                                <CheckBox IsChecked="{Binding IsSelected, Mode=TwoWay}"
                                          VerticalAlignment="Top" HorizontalAlignment="Left"
                                          Margin="8" Background="#CC111111"/>

                                <!-- Bilgiler (Alt) -->
                                <StackPanel Grid.Row="1" Margin="12,10,12,10" VerticalAlignment="Top">
                                    <TextBlock Text="{Binding Name}" Foreground="White" FontWeight="Bold" FontSize="16" TextTrimming="CharacterEllipsis" Margin="0,0,0,6"/>
                                    
                                    <Border HorizontalAlignment="Left" Background="#33000000" CornerRadius="4" Padding="6,3" Visibility="{Binding EstimatedValueText, Converter={StaticResource NullOrEmptyToCollapsedConverter}}" Margin="0,0,0,8">
                                        <TextBlock Text="{Binding EstimatedValueText}" Foreground="#4CAF50" FontSize="12" FontWeight="Bold"/>
                                    </Border>

                                    <!-- Card count + progress text -->
                                    <Grid Margin="0,0,0,6">
                                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Left">
                                            <TextBlock Text="{Binding RemainingCards}" Foreground="#FF8C00" FontSize="13" FontWeight="SemiBold"/>
                                            <TextBlock Text=" "/>
                                            <TextBlock Text="{Binding DataContext.Strings[CardsLeft], RelativeSource={RelativeSource AncestorType=UserControl}}" Foreground="#FF8C00" FontSize="13" FontWeight="SemiBold"/>
                                        </StackPanel>
                                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                                            <TextBlock Text="{Binding DroppedCards}" Foreground="#888" FontSize="11"/>
                                            <TextBlock Text=" / " Foreground="#888" FontSize="11"/>
                                            <TextBlock Text="{Binding InitialCards}" Foreground="#888" FontSize="11"/>
                                            <TextBlock Text=" "/>
                                            <TextBlock Text="{Binding DataContext.Strings[Dropped], RelativeSource={RelativeSource AncestorType=UserControl}}" Foreground="#888" FontSize="11"/>
                                        </StackPanel>
                                    </Grid>

                                    <!-- Progress Bar -->
                                    <ProgressBar Value="{Binding ProgressPercent, Mode=OneWay}" Minimum="0" Maximum="100" Height="6" Margin="0,0,0,10" Foreground="#4A90E2" Background="#333" BorderThickness="0"/>

                                    <Button Content="{Binding DataContext.Strings[QuickStart], RelativeSource={RelativeSource AncestorType=UserControl}}" Command="{Binding DataContext.StartSingleGameCommand, RelativeSource={RelativeSource AncestorType=UserControl}}" CommandParameter="{Binding}" FontSize="12" Padding="10,6" Background="#2E7D32" Foreground="White" BorderThickness="0" HorizontalAlignment="Stretch"/>
                                </StackPanel>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>

            <!-- Empty State -->
            <StackPanel Grid.Row="2" VerticalAlignment="Center" HorizontalAlignment="Center"
                        Visibility="{Binding HasNoGames, Converter={StaticResource BooleanToVisibilityConverter}, FallbackValue=Collapsed}">
                <ui:SymbolIcon Symbol="EmojiSad24" FontSize="48" Foreground="Gray" Margin="0,0,0,10"/>
                <TextBlock Text="{Binding Strings[NoCardsFound]}" FontSize="18" Foreground="Gray"/>
                <TextBlock Text="{Binding Strings[EnsureProfilePublic]}"
                           FontSize="12" Foreground="#666666" HorizontalAlignment="Center" Margin="0,5,0,0"/>
            </StackPanel>

            <!-- Loading Overlay -->
            <StackPanel Grid.Row="2" VerticalAlignment="Center" HorizontalAlignment="Center"
                        Visibility="{Binding IsRefreshingGames, Converter={StaticResource BooleanToVisibilityConverter}}">
                <ui:ProgressRing Height="40" Width="40" IsIndeterminate="True" Margin="0,0,0,10"/>
                <TextBlock Text="{Binding Strings[ScanningGames]}" FontSize="16" Foreground="Gray"/>
            </StackPanel>
        </Grid>
    </Grid>
</UserControl>
