<ui:FluentWindow x:Class="SteamCardIdler.MainWindow"
        Icon="Resources/tray.ico"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        xmlns:vm="clr-namespace:SteamCardIdler.ViewModels"
        xmlns:views="clr-namespace:SteamCardIdler.Views"
        xmlns:tb="clr-namespace:Hardcodet.Wpf.TaskbarNotification;assembly=Hardcodet.NotifyIcon.Wpf"
        xmlns:local="clr-namespace:SteamCardIdler.Helpers"
        Title="Steam Card Idler - v0.8.0" Height="700" Width="1160"
        WindowStartupLocation="CenterScreen"
        ExtendsContentIntoTitleBar="True"
        WindowBackdropType="Mica"
        d:DataContext="{d:DesignInstance vm:MainViewModel}"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        StateChanged="Window_StateChanged"
        Closing="Window_Closing">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="30"/>
        </Grid.RowDefinitions>

        <!-- System Tray Icon -->
        <tb:TaskbarIcon x:Name="TrayIcon"
                        ToolTipText="Steam Card Idler"
                        IconSource="/Resources/tray.ico"
                        TrayMouseDoubleClick="TrayIcon_TrayMouseDoubleClick">
            <tb:TaskbarIcon.ContextMenu>
                <ContextMenu>
                    <!-- User info (non-clickable header) -->
                    <MenuItem Header="{Binding UserProfile.PersonaName}"
                              IsEnabled="False"
                              FontWeight="Bold"/>
                    <Separator/>

                    <!-- Durum -->
                    <MenuItem Header="{Binding StatusText}"
                              IsEnabled="False"
                              Foreground="Gray"/>
                    <Separator/>

                    <!-- Kontroller -->
                    <MenuItem Header="Göster"
                              Click="ShowWindow_Click"/>
                    <MenuItem Header="{Binding PauseButtonText}"
                              Command="{Binding PauseResumeCommand}"
                              IsEnabled="{Binding IsIdling}"/>
                    <MenuItem Header="Durdur"
                              Command="{Binding StopIdleCommand}"
                              IsEnabled="{Binding IsIdling}"/>
                    <Separator/>
                    <MenuItem Header="Çıkış"
                              Command="{Binding ExitCommand}"/>
                </ContextMenu>
            </tb:TaskbarIcon.ContextMenu>
        </tb:TaskbarIcon>

        <!-- Title Bar -->
        <ui:TitleBar Title="Steam Card Idler - v0.9.0" Grid.Row="0">
            <ui:TitleBar.Header>
                <Button Command="{Binding OpenSettingsCommand}"
                        Visibility="{Binding IsLoggedIn, Converter={StaticResource BooleanToVisibilityConverter}}"
                        HorizontalAlignment="Right" Padding="8" Background="Transparent" BorderThickness="0">
                    <ui:SymbolIcon Symbol="Settings24"/>
                </Button>
            </ui:TitleBar.Header>
        </ui:TitleBar>

        <!-- Main Content Area -->
        <Grid Grid.Row="1">
            <views:LoginView Visibility="{Binding IsLoggedIn, Converter={StaticResource InverseBooleanToVisibilityConverter}}"/>
            <views:DashboardView Visibility="{Binding IsLoggedIn, Converter={StaticResource BooleanToVisibilityConverter}}"/>
        </Grid>

        <!-- Overlay Windows (Settings & Summary) -->
        <Grid Grid.Row="1" Panel.ZIndex="2000">
            <!-- Settings Overlay -->
            <Grid Background="#CC000000" Visibility="{Binding IsSettingsOpen, Converter={StaticResource BooleanToVisibilityConverter}}">
                <ui:Card VerticalAlignment="Center" HorizontalAlignment="Center" Width="450" Padding="30" Background="#1E2235">
                    <StackPanel>
                        <Grid Margin="0,0,0,20">
                            <TextBlock Text="{Binding Strings[Settings]}" FontSize="22" FontWeight="Bold" Foreground="White"/>
                            <Button HorizontalAlignment="Right" Command="{Binding CloseSettingsCommand}" Background="Transparent" BorderThickness="0">
                                <ui:SymbolIcon Symbol="Dismiss24"/>
                            </Button>
                        </Grid>

                        <TextBlock Text="{Binding Strings[LanguageSelection]}" FontWeight="SemiBold" Foreground="Gray" Margin="0,0,0,10"/>
                        <ComboBox ItemsSource="{Binding Languages}" SelectedItem="{Binding SelectedLanguage}" Margin="0,0,0,20"/>

                        <TextBlock Text="{Binding Strings[AutoActions]}" FontWeight="SemiBold" Foreground="Gray" Margin="0,10,0,10"/>
                        <ui:ToggleSwitch Content="{Binding Strings[AutoCloseApp]}" IsChecked="{Binding AutoCloseApp}" Margin="0,0,0,10"/>
                        <ui:ToggleSwitch Content="{Binding Strings[AutoShutdownPc]}" IsChecked="{Binding AutoShutdownPc}" Margin="0,0,0,10"/>
                        <ui:ToggleSwitch Content="{Binding Strings[ShowZeroCardGames]}" IsChecked="{Binding ShowZeroCardGames}" Margin="0,0,0,10"/>

                        <!-- Tray setting -->
                        <ui:ToggleSwitch Content="{Binding Strings[MinimizeToTray]}" IsChecked="{Binding MinimizeToTrayOnClose}" Margin="0,0,0,20"/>

                        <TextBlock Text="{Binding Strings[SecurityFilter]}" FontWeight="SemiBold" Foreground="Gray" Margin="0,10,0,10"/>
                        <Button Content="{Binding Strings[BlacklistVac]}" Command="{Binding SelectAllBacklistCommand}" HorizontalAlignment="Stretch" Padding="10"/>
                    </StackPanel>
                </ui:Card>
            </Grid>

            <!-- Summary Overlay -->
            <Grid Background="#CC000000" Visibility="{Binding IsSummaryOpen, Converter={StaticResource BooleanToVisibilityConverter}}">
                <ui:Card VerticalAlignment="Center" HorizontalAlignment="Center" Width="400" Padding="40" Background="#1E2235" BorderBrush="#2D3250">
                    <StackPanel HorizontalAlignment="Center">
                        <TextBlock Text="{Binding Strings[ProcessCompleted]}" FontSize="26" FontWeight="Bold" Foreground="White" HorizontalAlignment="Center" Margin="0,0,0,15"/>
                        <ui:SymbolIcon Symbol="CheckmarkCircle48" Filled="True" Foreground="#4CAF50" Margin="0,0,0,20"/>

                        <StackPanel Margin="0,0,0,30">
                            <TextBlock Text="{Binding SummaryTime}" FontSize="18" Foreground="#4A90E2" HorizontalAlignment="Center" Margin="0,0,0,8"/>
                            <TextBlock Text="{Binding SummaryCards}" FontSize="18" Foreground="White" HorizontalAlignment="Center" Margin="0,0,0,8"/>
                            <TextBlock Text="{Binding SummaryGames}" FontSize="18" Foreground="White" HorizontalAlignment="Center"/>
                        </StackPanel>

                        <Button Content="{Binding Strings[Awesome]}" HorizontalAlignment="Stretch" Padding="0,15" Command="{Binding CloseSummaryCommand}"/>
                    </StackPanel>
                </ui:Card>
            </Grid>
        </Grid>

        <!-- Footer -->
        <StatusBar Grid.Row="2" Background="#0F111A">
            <StatusBarItem HorizontalAlignment="Right">
                <TextBlock Text="v1.0.0 - Premium Edition" Foreground="#4A4A4A" FontSize="10" Margin="0,0,15,0"/>
            </StatusBarItem>
        </StatusBar>
    </Grid>
</ui:FluentWindow>
